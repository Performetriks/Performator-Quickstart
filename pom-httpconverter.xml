<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	
	<!-- ================= PROJECT INFORMATION ================== -->
	<modelVersion>4.0.0</modelVersion>
	<groupId>com.performetriks</groupId>
	<artifactId>exec-httpconverter</artifactId>
	<version>NO-VERSION</version>
	
	<name>Performator HTTP Converter</name>
	<description>This pom file is used to start the http converter.</description>

	<!-- ================= PROPERTIES ================== -->
	<properties>
		
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

		<skipJavadoc>true</skipJavadoc>
		<skipTests>true</skipTests>
		<skipZipReport>false</skipZipReport>
	</properties>
	
		<!-- ================= LICENSES ================== -->
	<licenses>
		<license>
			<name>MIT License</name>
			<url>https://github.com/Performetriks/Performator-Quickstart/blob/main/LICENSE</url>
		</license>
	</licenses>


	<!-- ================= DEPENDENCIES ================== -->
	<dependencies>
			
		<!-- https://mvnrepository.com/artifact/com.performetriks/performator -->
		<dependency>
		    <groupId>com.performetriks</groupId>
		    <artifactId>performator</artifactId>
		    <version>1.2.4</version>
		</dependency>
		
		<!-- https://mvnrepository.com/artifact/com.performetriks/performator-http -->
		<dependency>
		    <groupId>com.performetriks</groupId>
		    <artifactId>performator-conversion</artifactId>
		    <version>1.2.4</version>
		</dependency>
		
	</dependencies>


	<!-- ================= BUILD ================== -->
	<build>
		
  		<sourceDirectory>src/empty</sourceDirectory>

		<plugins>
		
			<!-- ================= COMPILER ================== -->
			<plugin>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.8.0</version>
				<configuration>
					<source>17</source>
					<target>17</target>
        			<skip>true</skip>
				</configuration>
			</plugin>

			<!-- ================= SHADED JAR ================== -->
			<plugin>
			    <groupId>org.apache.maven.plugins</groupId>
			    <artifactId>maven-shade-plugin</artifactId>
			    <version>3.6.0</version>
			    <executions>
			        <execution>
			            <phase>package</phase>
			            <goals>
			                <goal>shade</goal>
			            </goals>
			            <configuration>
			            	<filters>
						        <filter>
						            <artifact>*:*</artifact>
						            <excludes>
						                <exclude>META-INF/*.SF</exclude>
						                <exclude>META-INF/*.DSA</exclude>
						                <exclude>META-INF/*.RSA</exclude>
						            </excludes>
						        </filter>
						    </filters>
			                <transformers>
			                	<transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
			                    <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
			                        <manifestEntries>
			                            <Main-Class>com.performetriks.performator.conversion.httpconverter.PFRHttpConverter</Main-Class>
			                        	<Multi-Release>true</Multi-Release>
			                            <Specification-Title>${project.artifactId}</Specification-Title>
			                            <Specification-Version>${project.version}</Specification-Version>
			                            <Implementation-Title>${project.artifactId}</Implementation-Title>
			                            <Implementation-Version>${project.version}</Implementation-Version>
			                            <Implementation-Vendor-Id>${project.groupId}</Implementation-Vendor-Id>
			                        </manifestEntries>
			                    </transformer>
			                </transformers>
			            </configuration>
			        </execution>
			    </executions>
			</plugin>

			<!-- ================= EXEC ================== -->
			<plugin>
		        <groupId>org.codehaus.mojo</groupId>
		        <artifactId>exec-maven-plugin</artifactId>
		        <version>3.6.2</version>
		        <executions>
		          <execution>
					<phase>verify</phase>
		            <goals>
		              <goal>java</goal> <!-- when using exec:exec we can't automatically propagate -D properties -->
		            </goals>
		          </execution>
		        </executions>
				<configuration>
					<mainClass>com.performetriks.performator.conversion.httpconverter.PFRHttpConverter</mainClass>

					<!-- Prevent Maven from using target/classes -->
					<includeProjectDependencies>false</includeProjectDependencies>
					<includePluginDependencies>false</includePluginDependencies>

					<!-- Use ONLY the shaded jar -->
					<additionalClasspathElements>
						<additionalClasspathElement>
							${project.build.directory}/${project.build.finalName}.jar
						</additionalClasspathElement>
					</additionalClasspathElements>

					<!-- automatically propagate all -D argument values -->
					<systemProperties>
						<projectProperties />
					</systemProperties>
				</configuration>
		    </plugin>
			
		</plugins>

	</build>
</project>