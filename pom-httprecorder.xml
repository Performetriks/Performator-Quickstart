<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	
	<!-- ================= PROJECT INFORMATION ================== -->
	<modelVersion>4.0.0</modelVersion>
	<groupId>com.performetriks</groupId>
	<artifactId>exec-httprecorder</artifactId>
	<version>NO-VERSION</version>
	
	<name>Performator HTTP Recorder</name>
	<description>This pom file is used to start the http recorder.</description>

	<!-- ================= PROPERTIES ================== -->
	<properties>
		
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

		<skipJavadoc>true</skipJavadoc>
		<skipTests>true</skipTests>
		<skipZipReport>false</skipZipReport>
	</properties>
	
		<!-- ================= LICENSES ================== -->
	<licenses>
		<license>
			<name>MIT License</name>
			<url>https://github.com/Performetriks/Performator-Quickstart/blob/main/LICENSE</url>
		</license>
	</licenses>


	<!-- ================= DEPENDENCIES ================== -->
	<dependencies>
			
		<!-- https://mvnrepository.com/artifact/com.performetriks/performator -->
		<dependency>
		    <groupId>com.performetriks</groupId>
		    <artifactId>performator</artifactId>
		    <version>1.2.4</version>
		</dependency>
		
		<!-- https://mvnrepository.com/artifact/com.performetriks/performator-http -->
		<dependency>
		    <groupId>com.performetriks</groupId>
		    <artifactId>performator-httprecorder</artifactId>
		    <version>1.2.4</version>
		</dependency>
		
		<!-- https://mvnrepository.com/artifact/org.javassist/javassist -->
		<dependency>
		    <groupId>org.javassist</groupId>
		    <artifactId>javassist</artifactId>
		    <version>3.30.2-GA</version>
		    <scope>compile</scope>
		</dependency>
		
	</dependencies>


	<!-- ================= BUILD ================== -->
	<build>

  		<sourceDirectory>src/empty</sourceDirectory>

		<plugins>
		
			<!-- ================= COMPILER ================== -->
			<plugin>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.8.0</version>
				<configuration>
					<source>17</source>
					<target>17</target>
        			<skip>true</skip>
				</configuration>
			</plugin>

			<!-- ================= SHADED JAR ================== -->
			<plugin>
			    <groupId>org.apache.maven.plugins</groupId>
			    <artifactId>maven-shade-plugin</artifactId>
			    <version>3.6.0</version>
			    <executions>
			        <execution>
			            <phase>package</phase>
			            <goals>
			                <goal>shade</goal>
			            </goals>
			            <configuration>
			            	<filters>
						        <filter>
						            <artifact>*:*</artifact>
						            <excludes>
						                <exclude>META-INF/*.SF</exclude>
						                <exclude>META-INF/*.DSA</exclude>
						                <exclude>META-INF/*.RSA</exclude>
						            </excludes>
						        </filter>
						    </filters>
			                <transformers>
			                	<transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
			                    <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
			                        <manifestEntries>
			                        	<Premain-Class>com.performetriks.performator.httprecorder.injection.InjectionAgent</Premain-Class>
			                        	<Launcher-Agent-Class>com.performetriks.performator.httprecorder.injection.InjectionAgent</Launcher-Agent-Class>
			                            <Main-Class>com.performetriks.performator.httprecorder.PFRHttpRecorderUI</Main-Class>
			                        	<Multi-Release>true</Multi-Release>
			                            <Specification-Title>${project.artifactId}</Specification-Title>
			                            <Specification-Version>${project.version}</Specification-Version>
			                            <Implementation-Title>${project.artifactId}</Implementation-Title>
			                            <Implementation-Version>${project.version}</Implementation-Version>
			                            <Implementation-Vendor-Id>${project.groupId}</Implementation-Vendor-Id>
			                        </manifestEntries>
			                    </transformer>
			                </transformers>
			            </configuration>
			        </execution>
			    </executions>
			</plugin>

			<!-- ================= EXEC ================== -->
            <plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<version>3.6.2</version>
				<executions>
					<execution>
						<goals>
							<goal>exec</goal>
						</goals>
						<phase>integration-test</phase>
						<configuration>
							<executable>java</executable>

							<arguments>
								
								<argument>-javaagent:"${project.build.directory}/${project.build.finalName}.jar"</argument>
								<argument>--add-opens=java.base/java.lang=ALL-UNNAMED</argument>
								
								<argument>-XX:+UnlockExperimentalVMOptions</argument>
								<argument>-XX:+EnableJVMCI</argument>
								
								<argument>-classpath</argument>
					            <classpath />
					            
					            <argument>com.performetriks.performator.httprecorder.PFRHttpRecorderUI</argument>
					            
							</arguments>
						</configuration>
					</execution>
				</executions>
				<configuration>
					<systemProperties>
				    	<projectProperties /> <!-- automatically propagate all -D argument values -->
				    </systemProperties>
				</configuration>
			</plugin>
			
		</plugins>

	</build>
</project>